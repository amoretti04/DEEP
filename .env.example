# DIP — local dev environment
# Copy to .env and edit. NEVER commit .env.

# ── Core ─────────────────────────────────────────────────────────────
DIP_ENV=local
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Postgres (canonical store) ──────────────────────────────────────
POSTGRES_USER=dip
POSTGRES_PASSWORD=dip_local_only
POSTGRES_DB=dip
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://dip:dip_local_only@localhost:5432/dip

# ── Redis (rate limiting, cache) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── S3 / Minio (raw lake) ───────────────────────────────────────────
# In dev we point boto3 at Minio via endpoint_url.
RAW_LAKE_BUCKET=dip-raw
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=eu-central-1

# ── OpenSearch ──────────────────────────────────────────────────────
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin_local_only

# ── Kafka ───────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Temporal ────────────────────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=dip

# ── Prefect ─────────────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api

# ── API ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173

# ── Translation (on-demand + cached; ADR-0005) ─────────────────────
# TRANSLATION_SERVICE_URL points the API at whichever service is up:
#   - stub  (default compose-up)        → :8088
#   - NLLB-200 (profile `nllb`)         → :8089
# The app-side feature flag
# (UserSettings.translation.enabled) must also be true for translations
# to actually be requested.
TRANSLATION_SERVICE_URL=http://localhost:8088

# ── OTEL ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=dip-api
